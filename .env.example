# Public Supabase config (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only Supabase service role key (NEVER expose client-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Business Profile OAuth (server-only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback

# Google Places API (New) — vía de respaldo mientras esperamos la cuota de
# Business Profile. Solo requiere una API key (sin OAuth). Crear en Google
# Cloud Console → APIs & Services → Credentials, restringida a "Places API
# (New)". Cuota gratis: 1000 req/día.
GOOGLE_PLACES_API_KEY=

# Cron job protection
CRON_SECRET=generate-a-random-secret

# Brevo SMTP (transactional email — notificación al comercial cuando entra
# una reseña atribuida, alertas ≤2★, aviso de leads). Usa las mismas
# credenciales que Supabase Auth (custom SMTP). Brevo Dashboard → SMTP & API →
# SMTP. BREVO_SMTP_PASS es la SMTP key, NO la API key. Si dejas USER/PASS/FROM
# vacías el cron sigue funcionando pero no manda email (logea un warning).
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
BREVO_FROM_EMAIL=Atribuya <notificaciones@atribuya.com>
# A dónde llegan las respuestas: el FROM no es un buzón real, así que reply-to
# apunta a un correo que sí se lee. Opcional (si falta, no se pone reply-to).
BREVO_REPLY_TO=tu-correo@ejemplo.com
# Destinatario del aviso interno cuando entra un lead por la landing. Si falta,
# el lead se guarda igual en BD pero no se envía el email de aviso.
LEAD_NOTIFY_EMAIL=tu-correo@ejemplo.com

# App URL (used for absolute links in emails, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Analytics 4 (solo páginas públicas de marketing). El banner de
# consentimiento solo carga gtag tras el opt-in del usuario, y las peticiones
# reales solo se envían en producción (NODE_ENV=production). En dev, basta con
# definir esta var para poder probar el banner; no se envían hits a GA.
# Formato: G-XXXXXXXXXX. Definir también en Vercel (Production).
NEXT_PUBLIC_GA_ID=

# Sanity CMS (blog de marketing en /blog y /en/blog + Studio en /studio).
# Si faltan, la app degrada con elegancia: /blog muestra estado vacío,
# /studio muestra un aviso y el sitemap omite los posts.
# Se obtienen en https://sanity.io/manage. Definir también en Vercel.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
